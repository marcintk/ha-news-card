exports[`rssHtml > renders feed with title 1`] = `
"<!---->
    <div class="news-title"><!--?-->My Feed</div>
    <table class="news-table">
      <colgroup>
        <col class="img-col">
        <col>
      </colgroup>
      <!--?--><!---->
